# Database. The driver is inferred from the URL scheme:
#   file: / sqlite:  -> SQLite (libsql). Zero dependencies; great for local use.
#   postgres(ql):     -> Postgres. For a dedicated/shared server.
# Relative SQLite paths are resolved against the repo root.
DATABASE_URL=file:./data/claude_util.db
# DATABASE_URL=postgresql://user:password@localhost:5432/claude_util

API_PORT=8787
# Bind address for the API. 127.0.0.1 = same host only; 0.0.0.0 = all interfaces.
API_HOST=127.0.0.1
# Comma-separated browser origins allowed by CORS (web dev + pm2 static serve).
CORS_ORIGIN=http://localhost:4173,http://localhost:5173
# Port pm2 serves the built web dist on.
WEB_PORT=4173
# Build-time only: absolute API base the SPA fetches (static serve has no proxy).
# VITE_API_BASE=http://your-host:8787/api
# Optional override; defaults to ~/.claude
CLAUDE_DIR=
